# CAPTCHA Solving Service
# Sign up at https://www.capsolver.com/
CAPSOLVER_API_KEY=your_capsolver_api_key_here

# Postal (self-hosted email server)
# Get your Server API Key from Postal admin panel -> Servers -> your server -> Credentials
POSTAL_URL=https://postal.botwave.online
POSTAL_API_KEY=your_postal_server_api_key_here

# Email IMAP (fallback/alternative)
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Proxy settings (optional but recommended)
# Proxies are loaded from proxies.txt (Webshare format: host:port:user:pass)
# Or set a single proxy / rotating proxy endpoint:
PROXY_URL=
ROTATING_PROXY_URL=

# Account defaults
DEFAULT_PASSWORD=YourStr0ngP@ss!
BIRTH_YEAR=1998
BIRTH_MONTH=6
BIRTH_DAY=15

# Retry settings
MAX_RETRIES=3
RETRY_DELAY=10

# Concurrency (max simultaneous browser instances)
MAX_CONCURRENT=1
